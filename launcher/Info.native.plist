<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>pendpost</string>
  <key>CFBundleDisplayName</key>
  <string>pendpost</string>
  <key>CFBundleIdentifier</key>
  <string>pendpost.app</string>
  <key>CFBundleVersion</key>
  <string>1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleExecutable</key>
  <string>pendpost</string>
  <key>CFBundleIconFile</key>
  <string>AppIcon</string>
  <key>LSMinimumSystemVersion</key>
  <string>12.0</string>
  <key>NSHighResolutionCapable</key>
  <true/>
  <!-- Native WKWebView app: a REAL app (Dock icon, menu bar, Cmd-Tab) - NO
       LSUIElement, unlike the shell launcher fallback. -->
  <!-- The dashboard is served over loopback HTTP; NSAllowsLocalNetworking permits
       http://127.0.0.1 without weakening App Transport Security globally. -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsLocalNetworking</key>
    <true/>
  </dict>
</dict>
</plist>
