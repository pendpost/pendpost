# pendpost credentials. Copy to .env and fill in only the platforms you use.
# pendpost is always LIVE: a platform you have not connected is live-but-
# unauthenticated, so its publish/probe fails honestly until its credential below is
# present. You can still draft, approve, and schedule with no credentials - only
# publishing needs a connected platform.
#
# .env is gitignored - never commit real secrets.

# ---- Runtime (all optional) ----
# PENDPOST_MODE=mock          # test/demo fixture only: force every lane onto the mock driver
# PENDPOST_ROOT=/path/to/ws   # workspace for .env + config.json + data/ (default: install dir)
# PENDPOST_HOST=127.0.0.1     # bind host (the docker image sets 0.0.0.0)
# PENDPOST_PORT=8090          # port to bind

# ---- Always-on hardening (optional; OFF by default) ----
# The in-server auth gate activates ONLY when PENDPOST_HOST is non-loopback AND
# PENDPOST_AUTH_TOKEN is set. The loopback default stays no-auth and byte-for-byte
# unchanged. Use this when hosting pendpost on a public URL (deploy/fly.toml,
# railway.json, render.yaml), or keep the server loopback-only behind a zero-trust
# proxy (Tailscale, Cloudflare Access). See site-docs/always-on.mdx.
# PENDPOST_AUTH_TOKEN=        # bearer token required on every face (except GET /api/health) when the gate is on
# PENDPOST_PUBLIC_HOST=       # comma-list of host[:port] the deployment is reached at, e.g. pendpost.fly.dev

# ---- Meta (Facebook + Instagram) ----
# A long-lived Page token, or a System User token (preferred for automation).
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_IG_USER_ID=
META_PAGE_TOKEN=
META_SYSTEM_USER_TOKEN=
# META_PUBLISHING_PAUSED=false   # kill switch; "true" pauses the Meta lane

# ---- LinkedIn ----
# OAuth app credentials + the tokens minted by `node scripts/linkedin-social.mjs auth`.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=
LINKEDIN_ORG_URN=urn:li:organization:0000000
LINKEDIN_API_VERSION=202401

# ---- YouTube ----
# OAuth client + a durable refresh token from `node scripts/yt-social.mjs auth`.
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
YT_REDIRECT_URI=http://127.0.0.1:8723/oauth2callback

# ---- X (Twitter) ----
# Two auth paths. OAuth 1.0a (RECOMMENDED, no browser): app -> Keys and tokens ->
# generate BOTH the API Key/Secret AND the Access Token/Secret (set the app to
# Read+Write FIRST), then paste all four below. The lane goes live once
# X_ACCESS_TOKEN_SECRET is set. (See README "Going live" for the regenerate order.)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# OAuth 2.0 PKCE (alternative, browser): `node scripts/x-social.mjs auth` mints these.
# X_ACCESS_TOKEN above is shared by both flows; OAuth 2.0 adds the client + rotating refresh token.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=
X_TOKEN_EXPIRES_AT=
X_REDIRECT_URI=http://localhost:8087/callback
# X_HANDLE=yourhandle           # optional @handle (no @) for permalinks / the account link

# ---- Telegram (static bot token) ----
# From @BotFather; the bot must be an admin of the destination channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ---- Discord (static channel webhook) ----
DISCORD_WEBHOOK_URL=

# ---- Reddit (script app, beta lane) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=

# ---- Pinterest (OAuth, beta lane): `node scripts/pinterest-social.mjs auth` ----
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# ---- TikTok (OAuth, beta lane): `node scripts/tiktok-social.mjs auth` ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ---- Mastodon (static app token; Preferences -> Development on your instance) ----
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=

# ---- WordPress (application password; Users -> Profile -> Application Passwords) ----
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ---- Ghost (Admin API key from a custom integration, format <id>:<hexsecret>) ----
GHOST_SITE_URL=
GHOST_ADMIN_API_KEY=

# ---- Nostr (keypair lane: `node scripts/nostr-social.mjs keygen --save`) ----
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# ---- Google Business Profile (OAuth, beta lane): `node scripts/gbp-social.mjs auth` ----
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=
